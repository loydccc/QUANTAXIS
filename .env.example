# QUANTAXIS 2.1.0 Docker Compose 环境变量配置
# 复制此文件为 .env 并根据需要修改
#
# 作者: @yutiansut @quantaxis
# 版本: 2.1.0-alpha2

# ============================================================================
# MongoDB 配置
# ============================================================================
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change_me_in_production

MONGO_USER=quantaxis
MONGO_PASSWORD=quantaxis_password_change_me

# ============================================================================
# RabbitMQ 配置
# ============================================================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin_password_change_me

# ============================================================================
# Redis 配置
# ============================================================================
REDIS_PASSWORD=redis_password_change_me

# ============================================================================
# ClickHouse 配置
# ============================================================================
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_password_change_me

# ============================================================================
# QUANTAXIS 配置
# ============================================================================
QUANTAXIS_VERSION=2.1.0-alpha2

# 信号参数（可选；daily_pipeline.py 会读取这些值）
QUANTAXIS_SCORE_TEMP=0.35
QUANTAXIS_MAX_NAME_WEIGHT=0.1666666667
QUANTAXIS_MIN_TRADE_WEIGHT=0.005
QUANTAXIS_REBALANCE_TRIGGER_MODE=event_only
QUANTAXIS_REBALANCE_DRIFT_MIN_TURNOVER_2WAY=0.03
QUANTAXIS_REBALANCE_DRIFT_MAX_COST_BPS=25.0

# 执行与成本约束（可选）
QUANTAXIS_AUM_CNY=200000000
QUANTAXIS_ADV_PARTICIPATION_MAX=0.02
QUANTAXIS_IMPACT_K=0.01
QUANTAXIS_IMPACT_ALPHA=0.70
QUANTAXIS_IMPACT_LIQ_FLOOR=1000000
QUANTAXIS_IMPACT_COST_BUDGET_BPS=25.0
QUANTAXIS_FEE_BPS=8.0

# 因子权重（可选）
QUANTAXIS_SCORE_W_RET_20D=1.0
QUANTAXIS_SCORE_W_RET_10D=0.5
QUANTAXIS_SCORE_W_RET_5D=0.2
QUANTAXIS_SCORE_W_MA_60D=0.2
QUANTAXIS_SCORE_W_VOL_20D=-0.5
QUANTAXIS_SCORE_W_LIQ_20D=0.2

# =========================================================================
# Tushare 配置
# =========================================================================
# 从 https://tushare.pro 申请 token
TUSHARE_TOKEN=change_me

# 资源管理器配置
QA_RESOURCE_POOL_ENABLED=true
QA_AUTO_CLEANUP=true

# ============================================================================
# 时区配置
# ============================================================================
TZ=Asia/Shanghai

# ============================================================================
# 部署模式
# ============================================================================
# 可选值: development, staging, production
DEPLOY_ENV=development

# ============================================================================
# 注意事项
# ============================================================================
# 1. 生产环境必须修改所有默认密码
# 2. 建议使用强密码(至少12位,包含大小写字母、数字、特殊字符)
# 3. 不要将此文件提交到版本控制系统
# 4. 定期更新密码
